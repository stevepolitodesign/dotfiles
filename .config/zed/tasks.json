[
  {
    "label": "Rails test $ZED_RELATIVE_FILE -n /$ZED_CUSTOM_RUBY_TEST_NAME/",
    "command": "bin/rails",
    "args": [
      "test",
      "$ZED_RELATIVE_FILE",
      "-n",
      "\"$ZED_CUSTOM_RUBY_TEST_NAME\""
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": [
      "ruby-test"
    ]
  },
  {
    "label": "Minitest $ZED_RELATIVE_FILE -n /$ZED_CUSTOM_RUBY_TEST_NAME/",
    "command": "bundle",
    "args": [
      "exec",
      "ruby",
      "-Itest",
      "$ZED_RELATIVE_FILE",
      "-n",
      "\"$ZED_CUSTOM_RUBY_TEST_NAME\""
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": [
      "ruby-test"
    ]
  },
  {
    "label": "RSpec $ZED_RELATIVE_FILE:$ZED_ROW",
    "command": "bundle",
    "args": [
      "exec",
      "rspec",
      "\"$ZED_RELATIVE_FILE:$ZED_ROW\""
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": [
      "ruby-test"
    ]
  }
]
